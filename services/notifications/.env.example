PORT=4001
TODO_API_URL=http://localhost:3000/api
POLL_CRON=*/5 * * * *

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@todoapp.com

# Default notification channel: email, push, log, or webhook
DEFAULT_NOTIFICATION_CHANNEL=log

# Node environment
NODE_ENV=development
